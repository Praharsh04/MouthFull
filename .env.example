# MouthFull Environment Configuration

# ---------------------------------------------------------
# Application Mode
# ---------------------------------------------------------
# Set to 'development' to enable debug logs, 'production' for optimized mode.
APP_ENV=production

# ---------------------------------------------------------
# AI Provider API Keys
# ---------------------------------------------------------
# These are optional if configured via the UI. If set here, they override the UI.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# GEMINI_API_KEY=AIzaSy...
# GROQ_API_KEY=gsk_...
# TOGETHER_API_KEY=...

# ---------------------------------------------------------
# Advanced Settings
# ---------------------------------------------------------
# VAD_THRESHOLD=0.5
# LOG_LEVEL=INFO
